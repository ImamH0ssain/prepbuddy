# Optional API provider. If unset, PrepBuddy falls back to local Ollama.
GEMINI_API_KEY=
PREPBUDDY_LLM_PROVIDER=auto
PREPBUDDY_GEMINI_MODEL=gemini-3.1-flash-lite
PREPBUDDY_OLLAMA_BASE_URL=http://localhost:11434
PREPBUDDY_OLLAMA_MODEL=qwen3:4b-instruct
PREPBUDDY_OLLAMA_TIMEOUT_SECONDS=900
PREPBUDDY_DB_URL=sqlite:///data/prepbuddy.sqlite
